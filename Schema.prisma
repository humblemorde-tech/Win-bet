generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model User {
  id String @id @default(cuid())
  phone String @unique
  password String?
  balance Float @default(0)
  createdAt DateTime @default(now())
  bets Bet[]
  txns Transaction[]
}

model OTP {
  id String @id @default(cuid())
  phone String
  code String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Bet {
  id String @id @default(cuid())
  userId String
  game String
  amount Float
  result Float?
  status String @default("pending")
  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id])
}

model Transaction {
  id String @id @default(cuid())
  userId String
  type String // "deposit", "withdraw", "bet", "win"
  amount Float
  status String @default("success")
  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id])
}
